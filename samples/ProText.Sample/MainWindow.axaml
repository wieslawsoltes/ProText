<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:docs="using:Avalonia.Controls.Documents"
        xmlns:pro="https://github.com/avaloniaui"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="820"
        x:Class="ProText.Sample.MainWindow"
        Title="ProText"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="680">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#DDE3EC" BorderThickness="0,0,0,1" Padding="24,18">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">
                <StackPanel Spacing="4">
                    <TextBlock Classes="title" Text="ProText" />
                    <TextBlock Classes="caption" Text="Avalonia TextBlock compatibility with PretextSharp layout for plain and rich display text." />
                </StackPanel>
                <TextBlock x:Name="CacheStatusText"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Classes="caption" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="300,*">
            <Border Grid.Column="0" Background="#F9FAFC" BorderBrush="#DDE3EC" BorderThickness="0,0,1,0" Padding="20">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionTitle" Text="Corpus" />
                        <ComboBox x:Name="CorpusBox" SelectedIndex="1" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionTitle" Text="Font size" />
                        <Slider x:Name="FontSizeSlider" Minimum="11" Maximum="28" Value="16" TickFrequency="1" IsSnapToTickEnabled="True" />
                        <TextBlock x:Name="FontSizeValueText" Classes="caption" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionTitle" Text="Max lines" />
                        <Slider x:Name="MaxLinesSlider" Minimum="0" Maximum="12" Value="0" TickFrequency="1" IsSnapToTickEnabled="True" />
                        <TextBlock x:Name="MaxLinesValueText" Classes="caption" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <CheckBox x:Name="WrapCheckBox" Content="Wrap text" IsChecked="True" />
                        <CheckBox x:Name="CacheCheckBox" Content="Use global cache" IsChecked="True" />
                    </StackPanel>

                    <Button x:Name="ClearCacheButton" Content="Clear cache" HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>

            <TabControl Grid.Column="1" Margin="24">
                <TabItem Header="Comparison">
                    <ScrollViewer>
                        <StackPanel Spacing="18">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                        <Border Classes="panel" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="sectionTitle" Text="Avalonia TextBlock" />
                                <TextBlock x:Name="AvaloniaText"
                                           TextWrapping="Wrap"
                                           LineHeight="23"
                                           Foreground="#17202C" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Classes="panel" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="sectionTitle" Text="ProText" />
                                <pro:ProTextBlock x:Name="ProText"
                                                  TextWrapping="Wrap"
                                                  LineHeight="23"
                                                  Foreground="#17202C" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                        <Border Classes="panel" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="sectionTitle" Text="Inline TextBlock" />
                                <TextBlock TextWrapping="Wrap" LineHeight="24" Foreground="#17202C">
                                    <docs:Run Text="Inline content: " />
                                    <docs:Bold>bold</docs:Bold>
                                    <docs:Run Text=", " />
                                    <docs:Italic>italic</docs:Italic>
                                    <docs:Run Text=", and " />
                                    <docs:Underline>underlined</docs:Underline>
                                    <docs:Run Text=" runs use matching inline styling in both comparison columns." />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Classes="panel" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="sectionTitle" Text="Inline ProTextBlock" />
                                <pro:ProTextBlock TextWrapping="Wrap"
                                                  LineHeight="24"
                                                  Foreground="#17202C">
                                    <docs:Run Text="Inline content: " />
                                    <docs:Bold>bold</docs:Bold>
                                    <docs:Run Text=", " />
                                    <docs:Italic>italic</docs:Italic>
                                    <docs:Run Text=", and " />
                                    <docs:Underline>underlined</docs:Underline>
                                    <docs:Run Text=" runs use matching inline styling in both comparison columns." />
                                </pro:ProTextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Classes="panel" Padding="18">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                <TextBlock Classes="sectionTitle" Text="ProTextPresenter" />
                                <TextBlock Grid.Column="1" Classes="sectionTitle" Text="Inline ProTextPresenter" />
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                <Border Background="#F7FAFD" BorderBrush="#DDE3EC" BorderThickness="1" CornerRadius="6" Padding="12">
                                    <pro:ProTextPresenter x:Name="PresenterDemo"
                                                          Text="Presenter selection, caret, password masking, and preedit rendering share the ProText layout core."
                                                          TextWrapping="Wrap"
                                                          LineHeight="24"
                                                          SelectionStart="10"
                                                          SelectionEnd="29"
                                                          CaretIndex="45"
                                                          PreeditText="IME"
                                                          PreeditTextCursorPosition="2"
                                                          SelectionBrush="#663B82F6"
                                                          SelectionForegroundBrush="#FFFFFF"
                                                          Foreground="#17202C" />
                                </Border>

                                <Border Grid.Column="1" Background="#F7FAFD" BorderBrush="#DDE3EC" BorderThickness="1" CornerRadius="6" Padding="12">
                                    <pro:ProTextPresenter x:Name="PresenterInlineDemo"
                                                          TextWrapping="Wrap"
                                                          LineHeight="24"
                                                          Foreground="#17202C">
                                        <pro:ProTextPresenter.Inlines>
                                            <docs:Run Text="Presenter inline content: " />
                                            <docs:Bold>bold</docs:Bold>
                                            <docs:Run Text=", " />
                                            <docs:Italic>italic</docs:Italic>
                                            <docs:Run Text=", " />
                                            <docs:Underline>underlined</docs:Underline>
                                            <docs:Run Text=", and measured through reusable Pretext rich runs." />
                                        </pro:ProTextPresenter.Inlines>
                                    </pro:ProTextPresenter>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel" Padding="18">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                <TextBlock Classes="sectionTitle" Text="Avalonia TextBox" />
                                <TextBlock Grid.Column="1" Classes="sectionTitle" Text="ProTextBox" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                <TextBox x:Name="AvaloniaEditBox"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="118"
                                         LineHeight="23"
                                         SelectionBrush="#663B82F6"
                                         SelectionForegroundBrush="#FFFFFF" />

                                <pro:ProTextBox x:Name="ProEditBox"
                                                Grid.Column="1"
                                                AcceptsReturn="True"
                                                TextWrapping="Wrap"
                                                MinHeight="118"
                                                LineHeight="23"
                                                SelectionBrush="#663B82F6"
                                                SelectionForegroundBrush="#FFFFFF" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                <pro:ProTextBox x:Name="ProPlaceholderBox"
                                                PlaceholderText="Search cached prepared text"
                                                UseFloatingPlaceholder="True"
                                                TextWrapping="Wrap"
                                                LineHeight="23" />

                                <pro:ProTextBox x:Name="ProPasswordBox"
                                                Grid.Column="1"
                                                Classes="revealPasswordButton"
                                                Text="pretext-password"
                                                PasswordChar="*"
                                                TextWrapping="NoWrap"
                                                LineHeight="23" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel" Padding="18">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                <TextBlock Classes="sectionTitle" Text="Dense Avalonia TextBlocks" />
                                <TextBlock Grid.Column="1" Classes="sectionTitle" Text="Dense ProTextBlocks" />
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                <UniformGrid x:Name="AvaloniaDenseGrid" Columns="3" />
                                <UniformGrid x:Name="ProDenseGrid" Grid.Column="1" Columns="3" />
                            </Grid>
                        </StackPanel>
                    </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="1000 Avalonia TextBoxes">
                    <Grid RowDefinitions="Auto,*" RowSpacing="12">
                        <Border Classes="panel" Padding="12">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                <TextBlock Classes="sectionTitle" Text="Avalonia TextBox Surface" VerticalAlignment="Center" />
                                <Slider x:Name="AvaloniaTextBoxZoomSlider"
                                        Grid.Column="1"
                                        Minimum="0.01"
                                        Maximum="2.5"
                                        Value="1"
                                        TickFrequency="0.05" />
                                <TextBlock x:Name="AvaloniaTextBoxZoomText"
                                           Grid.Column="2"
                                           Width="48"
                                           Classes="caption"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                                <Button x:Name="AvaloniaTextBoxResetButton"
                                        Grid.Column="3"
                                        Content="Reset" />
                            </Grid>
                        </Border>

                        <Border x:Name="AvaloniaTextBoxViewport"
                                Grid.Row="1"
                                Classes="panel"
                                Background="#F5F7FA"
                                ClipToBounds="True">
                            <Canvas x:Name="AvaloniaTextBoxZoomSurface"
                                    Background="#F5F7FA">
                                <Canvas x:Name="AvaloniaTextBoxCanvas"
                                        RenderTransformOrigin="0,0" />
                            </Canvas>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="1000 ProTextBoxes">
                    <Grid RowDefinitions="Auto,*" RowSpacing="12">
                        <Border Classes="panel" Padding="12">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                <TextBlock Classes="sectionTitle" Text="ProTextBox Surface" VerticalAlignment="Center" />
                                <Slider x:Name="ProTextBoxZoomSlider"
                                        Grid.Column="1"
                                        Minimum="0.01"
                                        Maximum="2.5"
                                        Value="1"
                                        TickFrequency="0.05" />
                                <TextBlock x:Name="ProTextBoxZoomText"
                                           Grid.Column="2"
                                           Width="48"
                                           Classes="caption"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                                <Button x:Name="ProTextBoxResetButton"
                                        Grid.Column="3"
                                        Content="Reset" />
                            </Grid>
                        </Border>

                        <Border x:Name="ProTextBoxViewport"
                                Grid.Row="1"
                                Classes="panel"
                                Background="#F5F7FA"
                                ClipToBounds="True">
                            <Canvas x:Name="ProTextBoxZoomSurface"
                                    Background="#F5F7FA">
                                <Canvas x:Name="ProTextBoxCanvas"
                                        RenderTransformOrigin="0,0" />
                            </Canvas>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
